# ---- Authentication (server-only) ----
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# ---- LLM (OpenRouter -> gpt-4o-mini) ----
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.1

# ---- RAG (local embeddings + Chroma) ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_DIR=./chroma_db
RAG_TOP_K=3
# HF_TOKEN — optional for local dev (uses local model without it).
# REQUIRED in production (Render) to use HF Inference API and stay within 512MB RAM.
# Get a free token at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here

# ---- Mock integrations (no real creds needed) ----
SLACK_CHANNEL=#incidents
JIRA_PROJECT_KEY=INC

# ---- Optional: LangSmith tracing ----
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your_key
# LANGCHAIN_PROJECT=incident-suite
